# --- Setup -------------------------------------------------------------
# 1. Go to https://www.notion.so/profile/integrations and click "New integration".
#    Name it e.g. "Pharm Job Compare", workspace = your personal workspace.
#    Copy the "Internal Integration Token" (starts with `ntn_`).
# 2. Open the 藥師職缺資料庫 page in Notion. Click the ··· menu (top right) →
#    "Connections" → search for your integration → "Confirm".
# 3. Copy this file to `.env.local` and paste the token below.
# -----------------------------------------------------------------------

NOTION_TOKEN=ntn_paste_your_token_here

# Data source ID for 藥師職缺資料庫 (already known from the existing DB).
NOTION_DATA_SOURCE_ID=2036b934-0fd8-4b51-bd81-39ceea812897

# --- Contact form (FJUH card only) -------------------------------------
# Web3Forms access key. Get one free at https://web3forms.com by entering the
# email you want submissions delivered to — submissions are emailed straight
# there. This key is a public, email-bound key (safe to ship to the browser),
# so it's exposed via NEXT_PUBLIC_. Leave blank to hide the form entirely.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=
